<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.webServer>
    <handlers>
      <clear />
      <add name="Python FastCGI Restaurant" 
           path="*" 
           verb="*" 
           modules="FastCgiModule" 
           scriptProcessor="C:\Users\Unifi\AppData\Local\Python\pythoncore-3.14-64\python.exe|C:\Users\Unifi\AppData\Local\Python\pythoncore-3.14-64\Lib\site-packages\wfastcgi.py" 
           resourceType="Unspecified" 
           requireAccess="Script" />
    </handlers>
  </system.webServer>

  <location path="media">
    <system.webServer>
      <handlers>
        <clear />
        <add name="StaticFile" path="*" verb="*" modules="StaticFileModule,DefaultDocumentModule,DirectoryListingModule" resourceType="Either" />
      </handlers>
    </system.webServer>
  </location>

  <location path="staticfiles">
    <system.webServer>
      <handlers>
        <clear />
        <add name="StaticFile" path="*" verb="*" modules="StaticFileModule,DefaultDocumentModule,DirectoryListingModule" resourceType="Either" />
      </handlers>
    </system.webServer>
  </location>

  <appSettings>
    <add key="PYTHONPATH" value="C:\inetpub\wwwroot\FOLIUX\restaurant" />
    <add key="WSGI_HANDLER" value="restaurant.wsgi.application" />
    <add key="DJANGO_SETTINGS_MODULE" value="restaurant.settings" />
    <add key="WSGI_LOG" value="C:\inetpub\wwwroot\FOLIUX\restaurant\wfastcgi.log" />
  </appSettings>
</configuration>
