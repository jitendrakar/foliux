<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.webServer>
    <handlers>
      <add name="Python FastCGI" 
           path="*" 
           verb="*" 
           modules="FastCgiModule" 
           scriptProcessor="C:\Users\Unifi\AppData\Local\Python\pythoncore-3.14-64\python.exe|C:\Users\Unifi\AppData\Local\Python\pythoncore-3.14-64\Lib\site-packages\wfastcgi.py" 
           resourceType="Unspecified" 
           requireAccess="Script" />
    </handlers>
  </system.webServer>

  <location path="media">
    <system.webServer>
      <handlers>
        <clear />
        <add name="StaticFile" path="*" verb="*" modules="StaticFileModule,DefaultDocumentModule,DirectoryListingModule" resourceType="Either" />
      </handlers>
    </system.webServer>
  </location>

  <location path="static">
    <system.webServer>
      <handlers>
        <clear />
        <add name="StaticFile" path="*" verb="*" modules="StaticFileModule,DefaultDocumentModule,DirectoryListingModule" resourceType="Either" />
      </handlers>
    </system.webServer>
  </location>

  <appSettings>
    <add key="PYTHONPATH" value="C:\inetpub\wwwroot\FOLIUX" />
    <add key="WSGI_HANDLER" value="investment_advisory.wsgi.application" />
    <add key="DJANGO_SETTINGS_MODULE" value="investment_advisory.settings" />
    <add key="WSGI_LOG" value="C:\inetpub\wwwroot\FOLIUX\wfastcgi.log" />
  </appSettings>
</configuration>
<!-- Trigger reload after removing top Wealth Studio headers to save space -->
